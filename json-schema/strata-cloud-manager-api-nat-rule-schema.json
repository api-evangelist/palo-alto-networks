{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NatRule",
  "description": "A NAT policy rule defining source or destination address translation for matching traffic flows.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/strata-cloud-manager-api-nat-rule-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "readOnly": true
    },
    "name": {
      "type": "string"
    },
    "folder": {
      "type": "string",
      "readOnly": true
    },
    "position": {
      "type": "string",
      "enum": [
        "pre",
        "post"
      ]
    },
    "from": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Source zones."
    },
    "to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Destination zones."
    },
    "source": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "destination": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "service": {
      "type": "string",
      "description": "Service object name or any."
    },
    "source_translation": {
      "type": "object",
      "properties": {
        "dynamic_ip_and_port": {
          "type": "object",
          "properties": {
            "translated_address": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "static_ip": {
          "type": "object",
          "properties": {
            "translated_address": {
              "type": "string"
            },
            "bi_directional": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "destination_translation": {
      "type": "object",
      "properties": {
        "translated_address": {
          "type": "string"
        },
        "translated_port": {
          "type": "integer"
        }
      }
    },
    "nat_type": {
      "type": "string",
      "enum": [
        "ipv4",
        "nat64",
        "nptv6"
      ]
    },
    "disabled": {
      "type": "boolean",
      "default": false
    },
    "description": {
      "type": "string"
    },
    "tag": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
