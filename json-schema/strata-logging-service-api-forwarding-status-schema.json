{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForwardingStatus",
  "description": "ForwardingStatus schema from Palo Alto Networks Strata Logging Service API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/strata-logging-service-api-forwarding-status-schema.json",
  "type": "object",
  "properties": {
    "profile_id": {
      "type": "string",
      "description": "Log forwarding profile identifier."
    },
    "overall_status": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "error"
      ],
      "description": "Overall health status of the forwarding profile."
    },
    "destinations": {
      "type": "array",
      "description": "Per-destination status details.",
      "items": {
        "type": "object",
        "properties": {
          "destination_id": {
            "type": "string"
          },
          "destination_type": {
            "type": "string",
            "enum": [
              "syslog",
              "https",
              "email"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "error",
              "disabled"
            ]
          },
          "last_successful_delivery": {
            "type": "string",
            "format": "date-time"
          },
          "error_count_24h": {
            "type": "integer"
          },
          "last_error": {
            "type": "string"
          }
        }
      }
    }
  }
}
