{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IKEGateway",
  "description": "IKEGateway schema from Palo Alto Networks SASE Configuration Orchestration API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/sase-config-orchestration-api-ike-gateway-schema.json",
  "type": "object",
  "properties": {
    "peer_ip": {
      "type": "string",
      "description": "Public IP address of the remote peer gateway."
    },
    "peer_id": {
      "type": "string",
      "description": "IKE peer identity."
    },
    "local_ip": {
      "type": "string",
      "description": "Prisma Access local IKE gateway IP address."
    },
    "ike_version": {
      "type": "string",
      "enum": [
        "IKEv1",
        "IKEv2"
      ],
      "description": "IKE protocol version."
    },
    "authentication_type": {
      "type": "string",
      "enum": [
        "pre-shared-key",
        "certificate"
      ],
      "description": "IKE authentication method."
    }
  }
}
