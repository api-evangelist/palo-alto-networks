{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "User",
  "description": "User schema from Palo Alto Networks SaaS Security API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/saas-security-api-user-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique user identifier."
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User email address."
    },
    "display_name": {
      "type": "string",
      "description": "User display name."
    },
    "app_id": {
      "type": "string",
      "description": "SaaS application ID the user belongs to."
    },
    "account_type": {
      "type": "string",
      "enum": [
        "internal",
        "external",
        "service"
      ],
      "description": "Type of user account."
    },
    "last_activity": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the user's most recent activity."
    }
  }
}
