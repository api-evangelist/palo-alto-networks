{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityMetrics5G",
  "description": "SecurityMetrics5G schema from Palo Alto Networks SASE 5G Managed Services API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/sase-5g-api-security-metrics5-g-schema.json",
  "type": "object",
  "properties": {
    "period": {
      "type": "object",
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "total_sessions": {
      "type": "integer",
      "description": "Total 5G sessions inspected during the period."
    },
    "threats_detected": {
      "type": "integer",
      "description": "Number of threats detected in 5G traffic."
    },
    "threats_blocked": {
      "type": "integer",
      "description": "Number of threats blocked."
    },
    "bytes_inspected": {
      "type": "integer",
      "description": "Total bytes of 5G traffic inspected."
    },
    "active_subscribers": {
      "type": "integer",
      "description": "Number of active 5G subscribers."
    },
    "per_slice_metrics": {
      "type": "array",
      "description": "Metrics broken down by network slice.",
      "items": {
        "type": "object",
        "properties": {
          "slice_id": {
            "type": "string"
          },
          "slice_name": {
            "type": "string"
          },
          "sessions": {
            "type": "integer"
          },
          "threats_detected": {
            "type": "integer"
          },
          "bytes_inspected": {
            "type": "integer"
          }
        }
      }
    },
    "time_series": {
      "type": "array",
      "description": "Time-series data points for the metrics period.",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "sessions": {
            "type": "integer"
          },
          "threats": {
            "type": "integer"
          }
        }
      }
    }
  }
}
