{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EmailDestination",
  "description": "EmailDestination schema from Palo Alto Networks Strata Logging Service API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/strata-logging-service-api-email-destination-schema.json",
  "type": "object",
  "properties": {
    "destination_id": {
      "type": "string",
      "description": "Unique identifier of the email destination."
    },
    "name": {
      "type": "string",
      "description": "Display name of the destination."
    },
    "gateway": {
      "type": "string",
      "description": "SMTP server hostname."
    },
    "from": {
      "type": "string",
      "format": "email",
      "description": "Sender email address."
    },
    "to": {
      "type": "string",
      "format": "email",
      "description": "Recipient email address."
    },
    "and_also_to": {
      "type": "string",
      "format": "email",
      "description": "Additional recipient email address."
    },
    "enabled": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
