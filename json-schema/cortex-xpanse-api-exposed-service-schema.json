{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExposedService",
  "description": "An internet-exposed network service discovered on an asset.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cortex-xpanse-api-exposed-service-schema.json",
  "type": "object",
  "properties": {
    "service_id": {
      "type": "string"
    },
    "service_name": {
      "type": "string",
      "description": "Service name or protocol (e.g., HTTPS, SSH, RDP)."
    },
    "service_type": {
      "type": "string",
      "enum": [
        "APPLICATION_SERVER",
        "CLOUD_STORAGE",
        "DATABASE",
        "NETWORKING",
        "REMOTE_DESKTOP",
        "UNCLASSIFIED",
        "WEB"
      ]
    },
    "ip_address": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "port": {
      "type": "integer",
      "description": "TCP/UDP port number."
    },
    "protocol": {
      "type": "string",
      "enum": [
        "TCP",
        "UDP"
      ]
    },
    "provider": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Cloud or hosting providers detected for this service."
    },
    "business_units": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created": {
      "type": "integer",
      "description": "Service first discovery timestamp as Unix epoch milliseconds."
    },
    "last_observed": {
      "type": "integer"
    },
    "is_active": {
      "type": "string",
      "enum": [
        "Active",
        "Inactive",
        "Unconfirmed"
      ]
    },
    "discovery_type": {
      "type": "string",
      "enum": [
        "ColocatedOnIp",
        "DirectlyDiscovered",
        "CSP",
        "CertificateAssociation"
      ]
    }
  }
}
