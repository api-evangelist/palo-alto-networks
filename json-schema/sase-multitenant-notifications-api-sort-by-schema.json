{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SortBy",
  "description": "SortBy schema from Multi-Tenant Notifications API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/sase-multitenant-notifications-api-sort-by-schema.json",
  "type": "object",
  "properties": {
    "field": {
      "description": "Sort field",
      "type": "string",
      "enum": [
        "createdTime",
        "impactedTenantCount"
      ]
    },
    "sortBy": {
      "description": "Ascending or Descending",
      "type": "string",
      "enum": [
        "DESC",
        "ASC"
      ]
    }
  }
}
