{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cortex-xsoar-integration-manifest-schema.json",
  "title": "Cortex XSOAR Integration Manifest",
  "description": "Schema for the integration YAML manifest file used by Cortex XSOAR (formerly Demisto) content packs. The manifest defines the integration identity, configuration parameters, commands, arguments, outputs, and execution settings. Integration packs are published to the Cortex Marketplace and can be developed using the demisto-sdk CLI tool.",
  "type": "object",
  "required": ["commonfields", "name", "display", "category", "description", "configuration", "script"],
  "properties": {
    "commonfields": {
      "type": "object",
      "description": "Common fields for content identification.",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the integration. Must match across the manifest and code."
        },
        "version": {
          "type": "integer",
          "description": "Version number (always -1 for marketplace content).",
          "const": -1
        }
      }
    },
    "name": {
      "type": "string",
      "description": "Internal name of the integration. Must be unique within the content pack."
    },
    "display": {
      "type": "string",
      "description": "Display name shown in the XSOAR UI and Marketplace."
    },
    "category": {
      "type": "string",
      "description": "Integration category for Marketplace classification.",
      "enum": [
        "Analytics & SIEM",
        "Authentication & Identity Management",
        "Case Management",
        "Data Enrichment & Threat Intelligence",
        "Database",
        "Deception & Breach Simulation",
        "Email",
        "Endpoint",
        "Forensics & Malware Analysis",
        "IT Services",
        "Messaging and Conferencing",
        "Network Security",
        "Utilities",
        "Vulnerability Management"
      ]
    },
    "description": {
      "type": "string",
      "description": "Short description of the integration's purpose and capabilities."
    },
    "detaileddescription": {
      "type": "string",
      "description": "Detailed markdown description displayed on the Marketplace page."
    },
    "configuration": {
      "type": "array",
      "description": "Instance configuration parameters displayed in the integration settings UI.",
      "items": {
        "$ref": "#/$defs/ConfigurationParameter"
      }
    },
    "script": {
      "type": "object",
      "description": "Script execution settings and command definitions.",
      "required": ["type", "commands"],
      "properties": {
        "type": {
          "type": "string",
          "description": "Script language.",
          "enum": ["python", "python3", "javascript", "powershell"]
        },
        "subtype": {
          "type": "string",
          "description": "Python version for python type.",
          "enum": ["python2", "python3"]
        },
        "dockerimage": {
          "type": "string",
          "description": "Docker image for execution (e.g., demisto/python3:3.10.13.12345)."
        },
        "isfetch": {
          "type": "boolean",
          "description": "Whether the integration fetches incidents.",
          "default": false
        },
        "isfetchevents": {
          "type": "boolean",
          "description": "Whether the integration fetches events for XSIAM.",
          "default": false
        },
        "ismappable": {
          "type": "boolean",
          "description": "Whether fetched incidents support field mapping.",
          "default": false
        },
        "isremotesyncin": {
          "type": "boolean",
          "description": "Whether the integration supports incoming mirroring.",
          "default": false
        },
        "isremotesyncout": {
          "type": "boolean",
          "description": "Whether the integration supports outgoing mirroring.",
          "default": false
        },
        "longRunning": {
          "type": "boolean",
          "description": "Whether the integration runs as a long-running process.",
          "default": false
        },
        "longRunningPort": {
          "type": "boolean",
          "description": "Whether the long-running integration listens on a port.",
          "default": false
        },
        "runonce": {
          "type": "boolean",
          "description": "Whether the integration should run only once.",
          "default": false
        },
        "commands": {
          "type": "array",
          "description": "Commands exposed by the integration.",
          "items": {
            "$ref": "#/$defs/Command"
          }
        },
        "feed": {
          "type": "boolean",
          "description": "Whether the integration is a threat intelligence feed.",
          "default": false
        }
      }
    },
    "defaultmapperin": {
      "type": "string",
      "description": "Default incoming mapper for fetched incidents."
    },
    "defaultclassifier": {
      "type": "string",
      "description": "Default classifier for fetched incidents."
    },
    "fromversion": {
      "type": "string",
      "description": "Minimum XSOAR/XSIAM version (e.g., '6.0.0').",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "toversion": {
      "type": "string",
      "description": "Maximum XSOAR/XSIAM version.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "tests": {
      "type": "array",
      "description": "Test playbook names for CI/CD validation.",
      "items": {
        "type": "string"
      }
    },
    "marketplaces": {
      "type": "array",
      "description": "Target marketplaces for the integration.",
      "items": {
        "type": "string",
        "enum": ["xsoar", "marketplacev2", "xpanse", "xsoar_saas", "xsoar_on_prem"]
      }
    }
  },
  "$defs": {
    "ConfigurationParameter": {
      "type": "object",
      "description": "A configuration parameter for the integration instance.",
      "required": ["display", "name", "type", "required"],
      "properties": {
        "display": {
          "type": "string",
          "description": "Label displayed in the UI."
        },
        "name": {
          "type": "string",
          "description": "Parameter name used in code (e.g., params.get('api_key'))."
        },
        "type": {
          "type": "integer",
          "description": "Parameter type. 0=short text, 4=encrypted, 8=boolean, 9=auth, 12=text area, 15=single select, 16=multi select.",
          "enum": [0, 4, 8, 9, 12, 15, 16]
        },
        "required": {
          "type": "boolean",
          "description": "Whether the parameter is required for instance configuration."
        },
        "defaultvalue": {
          "type": "string",
          "description": "Default value for the parameter."
        },
        "additionalinfo": {
          "type": "string",
          "description": "Help text displayed below the input field."
        },
        "options": {
          "type": "array",
          "description": "Dropdown options for select-type parameters.",
          "items": {
            "type": "string"
          }
        },
        "hidden": {
          "type": "boolean",
          "description": "Whether the parameter is hidden from the UI.",
          "default": false
        },
        "section": {
          "type": "string",
          "description": "Configuration section grouping.",
          "enum": ["Connect", "Collect", "Optimize"]
        },
        "advanced": {
          "type": "boolean",
          "description": "Whether to show in the advanced section.",
          "default": false
        }
      }
    },
    "Command": {
      "type": "object",
      "description": "A command exposed by the integration.",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Command name (e.g., 'vendor-get-alerts'). Should follow vendor-action-noun pattern.",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "description": {
          "type": "string",
          "description": "Description of what the command does."
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether the command is deprecated.",
          "default": false
        },
        "arguments": {
          "type": "array",
          "description": "Command input arguments.",
          "items": {
            "$ref": "#/$defs/Argument"
          }
        },
        "outputs": {
          "type": "array",
          "description": "Command output context keys.",
          "items": {
            "$ref": "#/$defs/Output"
          }
        },
        "execution": {
          "type": "boolean",
          "description": "Whether the command makes changes (true = shows warning in War Room).",
          "default": false
        },
        "polling": {
          "type": "boolean",
          "description": "Whether the command supports the polling mechanism.",
          "default": false
        }
      }
    },
    "Argument": {
      "type": "object",
      "description": "An input argument for a command.",
      "required": ["name", "description"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Argument name."
        },
        "description": {
          "type": "string",
          "description": "Argument description."
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "default": {
          "type": "boolean",
          "description": "Whether this is the default argument (value passed without arg name).",
          "default": false
        },
        "defaultValue": {
          "type": "string",
          "description": "Default value for the argument."
        },
        "predefined": {
          "type": "array",
          "description": "Predefined allowed values.",
          "items": {
            "type": "string"
          }
        },
        "isArray": {
          "type": "boolean",
          "description": "Whether the argument accepts comma-separated values.",
          "default": false
        },
        "type": {
          "type": "string",
          "description": "Argument data type.",
          "enum": ["string", "number", "boolean", "date", "unknown"]
        }
      }
    },
    "Output": {
      "type": "object",
      "description": "An output context key produced by a command.",
      "required": ["contextPath", "description", "type"],
      "properties": {
        "contextPath": {
          "type": "string",
          "description": "Context key path (e.g., 'Vendor.Alert.ID')."
        },
        "description": {
          "type": "string",
          "description": "Description of the output value."
        },
        "type": {
          "type": "string",
          "description": "Output data type.",
          "enum": ["String", "Number", "Boolean", "Date", "Unknown"]
        }
      }
    }
  }
}
