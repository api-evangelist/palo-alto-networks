{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CloudAccount",
  "description": "CloudAccount schema from Palo Alto Networks Prisma Cloud CSPM API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-cspm-api-cloud-account-schema.json",
  "type": "object",
  "properties": {
    "accountId": {
      "type": "string",
      "description": "Cloud provider account identifier."
    },
    "name": {
      "type": "string",
      "description": "Display name of the account."
    },
    "cloudType": {
      "type": "string",
      "enum": [
        "aws",
        "azure",
        "gcp",
        "oci"
      ],
      "description": "Cloud provider type."
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether monitoring is enabled."
    },
    "numberOfPolicies": {
      "type": "integer",
      "description": "Number of policies applied to this account."
    },
    "lastModifiedTs": {
      "type": "integer",
      "description": "Epoch timestamp of last modification."
    }
  }
}
