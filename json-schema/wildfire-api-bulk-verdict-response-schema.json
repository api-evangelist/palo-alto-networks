{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BulkVerdictResponse",
  "description": "WildFire bulk verdict results for multiple hash queries.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/wildfire-api-bulk-verdict-response-schema.json",
  "type": "object",
  "properties": {
    "get-verdicts-info": {
      "type": "object",
      "properties": {
        "entry": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "md5": {
                "type": "string"
              },
              "sha256": {
                "type": "string"
              },
              "verdict": {
                "type": "integer"
              }
            }
          }
        }
      }
    }
  }
}
