{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExportJobResponse",
  "description": "Response from a submitted export job",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-access-insights-api-export-job-response-schema.json",
  "type": "object",
  "properties": {
    "job_id": {
      "type": "string",
      "description": "Unique identifier for the export job"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "RUNNING",
        "COMPLETED",
        "FAILED"
      ],
      "description": "Current job status"
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time",
      "description": "Job submission timestamp"
    }
  }
}
