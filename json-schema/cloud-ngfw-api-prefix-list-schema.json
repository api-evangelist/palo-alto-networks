{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PrefixList",
  "description": "An IP prefix list containing CIDR entries for use in security rule source and destination criteria.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cloud-ngfw-api-prefix-list-schema.json",
  "type": "object",
  "properties": {
    "PrefixListName": {
      "type": "string"
    },
    "PrefixListEntry": {
      "type": "object",
      "properties": {
        "Description": {
          "type": "string"
        },
        "PrefixList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "CIDR block entries (e.g., 10.0.0.0/8, 192.168.0.0/16)."
        }
      }
    },
    "UpdateToken": {
      "type": "string"
    }
  }
}
