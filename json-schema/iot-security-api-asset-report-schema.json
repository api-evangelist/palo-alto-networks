{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssetReport",
  "description": "AssetReport schema from Palo Alto Networks IoT Security API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/iot-security-api-asset-report-schema.json",
  "type": "object",
  "properties": {
    "total_devices": {
      "type": "integer",
      "description": "Total number of discovered devices."
    },
    "monitored_devices": {
      "type": "integer",
      "description": "Number of actively monitored devices."
    },
    "by_category": {
      "type": "object",
      "description": "Device count breakdown by category.",
      "additionalProperties": {
        "type": "integer"
      }
    },
    "by_risk_level": {
      "type": "object",
      "description": "Device count breakdown by risk level.",
      "properties": {
        "critical": {
          "type": "integer"
        },
        "high": {
          "type": "integer"
        },
        "medium": {
          "type": "integer"
        },
        "low": {
          "type": "integer"
        }
      }
    },
    "by_site": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "site": {
            "type": "string"
          },
          "device_count": {
            "type": "integer"
          }
        }
      },
      "description": "Device count breakdown by network site."
    },
    "top_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "profile": {
            "type": "string"
          },
          "device_count": {
            "type": "integer"
          }
        }
      },
      "description": "Most common device profiles."
    },
    "report_time": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the report was generated."
    }
  }
}
