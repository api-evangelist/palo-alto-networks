{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DefenderSummary",
  "description": "DefenderSummary schema from Palo Alto Networks Prisma Cloud Compute API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-compute-api-defender-summary-schema.json",
  "type": "object",
  "properties": {
    "total": {
      "type": "integer",
      "description": "Total number of deployed Defenders."
    },
    "connected": {
      "type": "integer",
      "description": "Number of currently connected Defenders."
    },
    "disconnected": {
      "type": "integer",
      "description": "Number of disconnected Defenders."
    },
    "by_type": {
      "type": "object",
      "description": "Defender count breakdown by deployment type.",
      "properties": {
        "docker": {
          "type": "integer"
        },
        "dockerWindows": {
          "type": "integer"
        },
        "cri": {
          "type": "integer"
        },
        "fargate": {
          "type": "integer"
        },
        "appEmbedded": {
          "type": "integer"
        },
        "serverless": {
          "type": "integer"
        }
      }
    },
    "version_distribution": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          }
        }
      }
    }
  }
}
