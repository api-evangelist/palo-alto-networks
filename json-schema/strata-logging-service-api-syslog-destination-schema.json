{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SyslogDestination",
  "description": "SyslogDestination schema from Palo Alto Networks Strata Logging Service API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/strata-logging-service-api-syslog-destination-schema.json",
  "type": "object",
  "properties": {
    "destination_id": {
      "type": "string",
      "description": "Unique identifier of the syslog destination."
    },
    "name": {
      "type": "string",
      "description": "Display name of the destination."
    },
    "server": {
      "type": "string",
      "description": "Syslog server hostname or IP address."
    },
    "port": {
      "type": "integer",
      "description": "Syslog server port."
    },
    "protocol": {
      "type": "string",
      "enum": [
        "UDP",
        "TCP",
        "SSL"
      ],
      "description": "Transport protocol for syslog delivery."
    },
    "format": {
      "type": "string",
      "enum": [
        "IETF",
        "BSD",
        "CSV"
      ],
      "description": "Syslog message format."
    },
    "facility": {
      "type": "string",
      "description": "Syslog facility value."
    },
    "enabled": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
