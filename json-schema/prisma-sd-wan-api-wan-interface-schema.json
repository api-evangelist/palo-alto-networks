{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WANInterface",
  "description": "WANInterface schema from Palo Alto Networks Prisma SD-WAN API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-sd-wan-api-wan-interface-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the WAN interface.",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "description": "Name of the WAN interface."
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "publicwan",
        "privatewan"
      ],
      "description": "Type of WAN connection."
    },
    "link_bw_down": {
      "type": "number",
      "description": "Downstream bandwidth in Mbps."
    },
    "link_bw_up": {
      "type": "number",
      "description": "Upstream bandwidth in Mbps."
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255,
      "description": "Cost metric for path selection. Lower cost is preferred."
    },
    "lqm_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether Link Quality Monitoring is enabled."
    },
    "label_id": {
      "type": "string",
      "description": "WAN interface label for policy-based routing."
    },
    "site_id": {
      "type": "string",
      "readOnly": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    }
  },
  "required": [
    "name",
    "type"
  ]
}
