{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssetInternetExposure",
  "description": "Summary of an internet-exposed asset discovered by Xpanse.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cortex-xpanse-api-asset-internet-exposure-schema.json",
  "type": "object",
  "properties": {
    "asm_id_list": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of ASM identifiers for this asset."
    },
    "asset_name": {
      "type": "string",
      "description": "Asset hostname, IP address, or identifier."
    },
    "asset_type": {
      "type": "string",
      "enum": [
        "CERTIFICATE",
        "CLOUD_COMPUTE_INSTANCE",
        "CLOUD_LOAD_BALANCER",
        "CLOUD_OBJECT_STORAGE",
        "DOMAIN",
        "NETWORKING_DEVICE",
        "ON_PREM_SERVER",
        "UNMANAGED_NETWORK_DEVICE"
      ]
    },
    "ip_address": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IP addresses associated with this asset."
    },
    "domain": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Domain names associated with this asset."
    },
    "ipv6_address": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cloud_id": {
      "type": "string",
      "description": "Cloud provider resource identifier."
    },
    "cloud_provider": {
      "type": "string",
      "enum": [
        "AWS",
        "Azure",
        "GCP",
        "OTHER"
      ]
    },
    "externally_detected_providers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "business_units": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Business units associated with this asset."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    },
    "created": {
      "type": "integer",
      "description": "Asset first discovery timestamp as Unix epoch milliseconds."
    },
    "last_observed": {
      "type": "integer",
      "description": "Most recent observation timestamp as Unix epoch milliseconds."
    }
  }
}
