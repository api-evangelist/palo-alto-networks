{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MfaActivity",
  "description": "MfaActivity schema from Incident Security Service Posture Management API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/identity-security-posture-management-api-mfa-activity-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant": {
      "type": "string"
    },
    "userId": {
      "type": "string"
    },
    "idpId": {
      "type": "string"
    },
    "idpType": {
      "type": "string"
    },
    "mfaStrength": {
      "type": "string"
    },
    "admin": {
      "type": "boolean"
    },
    "appType": {
      "type": "string"
    },
    "appId": {
      "type": "string"
    },
    "timestamp": {
      "format": "date-time",
      "type": "string",
      "example": "2022-03-10T16:15:50+00:00"
    },
    "mfaFactors": {
      "type": "string"
    },
    "saasProviderMfaType": {
      "type": "string"
    },
    "fullName": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "ipAddress": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "ticketKey": {
      "type": "string"
    },
    "ticketUrl": {
      "type": "string"
    }
  }
}
