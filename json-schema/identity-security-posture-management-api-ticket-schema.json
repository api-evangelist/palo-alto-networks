{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ticket",
  "description": "Ticket schema from Incident Security Service Posture Management API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/identity-security-posture-management-api-ticket-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "tenant": {
      "type": "string"
    },
    "saasInstanceId": {
      "type": "string"
    },
    "resourceIds": {
      "type": "string"
    },
    "feature": {
      "type": "string"
    },
    "users": {
      "type": "string"
    },
    "integrationId": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "ticketKey": {
      "type": "string"
    },
    "ticketUrl": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "type": "string",
      "example": "2022-03-10T16:15:50+00:00"
    }
  }
}
