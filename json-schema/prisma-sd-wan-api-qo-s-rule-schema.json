{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QoSRule",
  "description": "QoSRule schema from Palo Alto Networks Prisma SD-WAN API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-sd-wan-api-qo-s-rule-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the QoS rule.",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "description": "Name of the QoS rule."
    },
    "description": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "default"
      ],
      "description": "Traffic priority for matching flows."
    },
    "dscp_class": {
      "type": "string",
      "description": "DSCP class to apply for marking traffic."
    },
    "app_filters": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Application names or identifiers this rule applies to."
    },
    "bandwidth_limit_up": {
      "type": "number",
      "description": "Upstream bandwidth limit in Mbps for matched traffic."
    },
    "bandwidth_limit_down": {
      "type": "number",
      "description": "Downstream bandwidth limit in Mbps for matched traffic."
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether the rule is active."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    }
  },
  "required": [
    "name"
  ]
}
