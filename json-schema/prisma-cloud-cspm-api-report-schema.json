{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Report",
  "description": "Report schema from Palo Alto Networks Prisma Cloud CSPM API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-cspm-api-report-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique report identifier."
    },
    "name": {
      "type": "string",
      "description": "Report name."
    },
    "type": {
      "type": "string",
      "description": "Report type.",
      "enum": [
        "RIS",
        "COMPLIANCE",
        "ALERT"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ],
      "description": "Current report generation status."
    },
    "createdOn": {
      "type": "integer",
      "description": "Epoch timestamp when the report was created."
    },
    "lastModifiedOn": {
      "type": "integer",
      "description": "Epoch timestamp of last modification."
    },
    "downloadUrl": {
      "type": "string",
      "description": "URL for downloading the completed report."
    }
  }
}
