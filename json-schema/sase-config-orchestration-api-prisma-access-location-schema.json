{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PrismaAccessLocation",
  "description": "PrismaAccessLocation schema from Palo Alto Networks SASE Configuration Orchestration API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/sase-config-orchestration-api-prisma-access-location-schema.json",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Location identifier used in API requests."
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable location name."
    },
    "region": {
      "type": "string",
      "description": "Geographic region (e.g., americas, europe, asia-pacific)."
    },
    "country": {
      "type": "string",
      "description": "Country code (ISO 3166-1 alpha-2)."
    },
    "city": {
      "type": "string",
      "description": "City name."
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "limited",
        "unavailable"
      ],
      "description": "Current availability status."
    }
  }
}
