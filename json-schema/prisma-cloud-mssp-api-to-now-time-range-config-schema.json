{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToNowTimeRangeConfig",
  "description": "ToNowTimeRangeConfig schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-mssp-api-to-now-time-range-config-schema.json",
  "type": "object",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "timeUnit": {
          "type": "string"
        },
        "timeValue": {
          "type": "integer",
          "format": "int32"
        }
      },
      "discriminator": {
        "propertyName": "type"
      }
    },
    {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "enum": [
            "week",
            "month",
            "year"
          ]
        }
      }
    }
  ]
}
