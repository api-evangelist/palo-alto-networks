{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ManagedDevice",
  "description": "ManagedDevice schema from Palo Alto Networks Prisma Access Browser Management API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-access-browser-api-managed-device-schema.json",
  "type": "object",
  "properties": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier of the managed device."
    },
    "hostname": {
      "type": "string",
      "description": "Device hostname."
    },
    "platform": {
      "type": "string",
      "enum": [
        "windows",
        "macos",
        "linux",
        "chromeos"
      ],
      "description": "Operating system platform."
    },
    "browser_version": {
      "type": "string",
      "description": "Installed Prisma Access Browser version."
    },
    "compliance_status": {
      "type": "string",
      "enum": [
        "compliant",
        "non_compliant",
        "unknown"
      ],
      "description": "Device compliance status."
    },
    "user_id": {
      "type": "string",
      "description": "ID of the last user who logged in on this device."
    },
    "last_seen_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the device's last check-in."
    }
  }
}
