{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LogForwardingProfile",
  "description": "LogForwardingProfile schema from Palo Alto Networks Strata Logging Service API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/strata-logging-service-api-log-forwarding-profile-schema.json",
  "type": "object",
  "properties": {
    "profile_id": {
      "type": "string",
      "description": "Unique identifier of the profile."
    },
    "name": {
      "type": "string",
      "description": "Display name of the profile."
    },
    "description": {
      "type": "string",
      "description": "Description of the profile's purpose."
    },
    "log_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "traffic",
          "threat",
          "url",
          "wildfire",
          "auth",
          "decryption",
          "globalprotect",
          "system",
          "config"
        ]
      },
      "description": "Log types included in this forwarding profile."
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether this profile is actively forwarding logs."
    },
    "destination_count": {
      "type": "integer",
      "description": "Total number of configured destinations."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
