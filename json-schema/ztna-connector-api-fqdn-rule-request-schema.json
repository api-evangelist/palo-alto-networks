{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FQDNRuleRequest",
  "description": "FQDNRuleRequest schema from Palo Alto Networks ZTNA Connector API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/ztna-connector-api-fqdn-rule-request-schema.json",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for the FQDN rule."
    },
    "fqdn_pattern": {
      "type": "string",
      "description": "FQDN pattern or wildcard this rule matches."
    },
    "group_id": {
      "type": "string",
      "description": "Connector group to use for matching FQDNs."
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "description": "Ports covered by this rule."
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name",
    "fqdn_pattern",
    "group_id"
  ]
}
