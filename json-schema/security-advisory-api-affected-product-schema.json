{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AffectedProduct",
  "description": "AffectedProduct schema from Palo Alto Networks Security Advisory API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/security-advisory-api-affected-product-schema.json",
  "type": "object",
  "properties": {
    "product": {
      "type": "string",
      "description": "Product name (e.g., PAN-OS, Cortex XDR Agent)."
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": {
            "type": "string",
            "description": "Affected version or version range."
          },
          "status": {
            "type": "string",
            "enum": [
              "Affected",
              "Unaffected",
              "Fixed"
            ],
            "description": "Vulnerability status for this version."
          }
        }
      }
    }
  }
}
