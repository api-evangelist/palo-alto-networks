{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UpdateMsspRequest",
  "description": "UpdateMsspRequest schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-mssp-api-update-mssp-request-schema.json",
  "type": "object",
  "properties": {
    "name": {
      "maxLength": 63,
      "minLength": 3,
      "type": "string"
    },
    "addLicensePool": {
      "required": [
        "credits",
        "endDate",
        "poolName",
        "serialNumber",
        "startDate"
      ],
      "type": "object",
      "properties": {
        "serialNumber": {
          "type": "string"
        },
        "poolName": {
          "maxLength": 63,
          "minLength": 3,
          "type": "string"
        },
        "startDate": {
          "type": "integer",
          "format": "int64"
        },
        "endDate": {
          "type": "integer",
          "format": "int64"
        },
        "credits": {
          "minimum": 1,
          "type": "integer",
          "format": "int32"
        }
      }
    }
  }
}
