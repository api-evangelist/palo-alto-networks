{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job",
  "description": "An asynchronous job tracking configuration push or commit operations.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/strata-cloud-manager-api-job-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique job identifier."
    },
    "type": {
      "type": "string",
      "description": "Job type (e.g., push, commit)."
    },
    "status": {
      "type": "string",
      "enum": [
        "PEND",
        "ACT",
        "FIN",
        "FAIL"
      ],
      "description": "Current job status."
    },
    "result": {
      "type": "string",
      "enum": [
        "OK",
        "FAIL",
        "WARN"
      ]
    },
    "start_ts": {
      "type": "string",
      "format": "date-time",
      "description": "Job start timestamp."
    },
    "end_ts": {
      "type": "string",
      "format": "date-time",
      "description": "Job completion timestamp."
    },
    "percent": {
      "type": "integer",
      "description": "Job completion percentage (0-100)."
    },
    "details": {
      "type": "object",
      "description": "Additional job details and error messages."
    }
  }
}
