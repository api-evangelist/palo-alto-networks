{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OwnedIpRange",
  "description": "An IP range owned by the organization and monitored by Xpanse.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cortex-xpanse-api-owned-ip-range-schema.json",
  "type": "object",
  "properties": {
    "range_id": {
      "type": "string"
    },
    "cidr": {
      "type": "string",
      "description": "IP range in CIDR notation (e.g., 203.0.113.0/24)."
    },
    "first_ip": {
      "type": "string"
    },
    "last_ip": {
      "type": "string"
    },
    "range_size": {
      "type": "integer",
      "description": "Number of IP addresses in the range."
    },
    "business_units": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attribution_reason": {
      "type": "string",
      "enum": [
        "RIR",
        "InternallyAttributed",
        "ExternallyAttributed"
      ]
    },
    "created": {
      "type": "integer",
      "description": "Range creation timestamp as Unix epoch milliseconds."
    },
    "modified": {
      "type": "integer"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    }
  }
}
