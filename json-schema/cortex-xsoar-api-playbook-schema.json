{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Playbook",
  "description": "A Cortex XSOAR playbook defining an automated response workflow.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cortex-xsoar-api-playbook-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "readOnly": true
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fromVersion": {
      "type": "string",
      "description": "Minimum XSOAR version required."
    },
    "toVersion": {
      "type": "string"
    },
    "deprecated": {
      "type": "boolean"
    }
  }
}
