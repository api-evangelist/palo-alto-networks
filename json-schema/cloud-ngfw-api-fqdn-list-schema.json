{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FqdnList",
  "description": "An FQDN list containing domain name entries for use in security rule destination criteria.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cloud-ngfw-api-fqdn-list-schema.json",
  "type": "object",
  "properties": {
    "FqdnListName": {
      "type": "string"
    },
    "FqdnListEntry": {
      "type": "object",
      "properties": {
        "Description": {
          "type": "string"
        },
        "FqdnList": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Fully qualified domain names (e.g., example.com, *.example.com)."
        }
      }
    },
    "UpdateToken": {
      "type": "string"
    }
  }
}
