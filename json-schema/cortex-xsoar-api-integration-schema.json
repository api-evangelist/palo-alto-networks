{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Integration",
  "description": "A Cortex XSOAR integration pack providing connectivity to a third-party tool.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cortex-xsoar-api-integration-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "display": {
      "type": "string",
      "description": "Human-readable display name."
    },
    "category": {
      "type": "string",
      "description": "Integration category (e.g., Endpoint, Firewall, SIEM)."
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "integer"
    },
    "fromVersion": {
      "type": "string"
    },
    "deprecated": {
      "type": "boolean"
    },
    "beta": {
      "type": "boolean"
    }
  }
}
