{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RelativeTimeRangeConfig",
  "description": "RelativeTimeRangeConfig schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-mssp-api-relative-time-range-config-schema.json",
  "type": "object",
  "allOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "timeUnit": {
          "type": "string"
        },
        "timeValue": {
          "type": "integer",
          "format": "int32"
        }
      },
      "discriminator": {
        "propertyName": "type"
      }
    },
    {
      "type": "object",
      "properties": {
        "value": {
          "type": "object",
          "properties": {
            "unit": {
              "type": "string",
              "enum": [
                "week",
                "month",
                "year"
              ]
            },
            "amount": {
              "type": "integer",
              "description": "Number of time units",
              "format": "int32"
            }
          }
        }
      }
    }
  ]
}
