{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Entitlement",
  "description": "Entitlement schema from Palo Alto Networks SASE Subscription Service API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/sase-subscription-api-entitlement-schema.json",
  "type": "object",
  "properties": {
    "feature": {
      "type": "string",
      "description": "Feature or capability name."
    },
    "licensed_quantity": {
      "type": "integer",
      "description": "Licensed quantity for this entitlement."
    },
    "allocated_quantity": {
      "type": "integer",
      "description": "Quantity already allocated to child TSGs."
    },
    "available_quantity": {
      "type": "integer",
      "description": "Remaining quantity available for allocation."
    },
    "unit": {
      "type": "string",
      "description": "Unit of measure."
    }
  }
}
