{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CIScan",
  "description": "CIScan schema from Palo Alto Networks Prisma Cloud Compute API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-compute-api-ci-scan-schema.json",
  "type": "object",
  "properties": {
    "entityInfo": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "ciImage",
            "ciServerless",
            "ciIaC"
          ]
        },
        "hostname": {
          "type": "string"
        },
        "scanTime": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "pass": {
      "type": "boolean",
      "description": "Whether the scan passed the configured policy thresholds."
    },
    "vulnerabilitiesCount": {
      "type": "integer"
    },
    "complianceIssuesCount": {
      "type": "integer"
    },
    "vulnerabilityDistribution": {
      "type": "object",
      "properties": {
        "critical": {
          "type": "integer"
        },
        "high": {
          "type": "integer"
        },
        "medium": {
          "type": "integer"
        },
        "low": {
          "type": "integer"
        }
      }
    }
  }
}
