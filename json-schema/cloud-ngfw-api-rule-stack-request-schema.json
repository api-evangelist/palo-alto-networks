{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuleStackRequest",
  "description": "RuleStackRequest schema from Palo Alto Networks Cloud NGFW for AWS REST API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/cloud-ngfw-api-rule-stack-request-schema.json",
  "type": "object",
  "properties": {
    "RuleStackName": {
      "type": "string"
    },
    "RuleStackEntry": {
      "type": "object",
      "properties": {
        "Description": {
          "type": "string"
        },
        "Scope": {
          "type": "string",
          "enum": [
            "Local",
            "Global"
          ],
          "default": "Local"
        },
        "MinAppIdVersion": {
          "type": "string"
        },
        "Profile": {
          "type": "object",
          "properties": {
            "AntiSpywareProfile": {
              "type": "string"
            },
            "AntiVirusProfile": {
              "type": "string"
            },
            "VulnerabilityProfile": {
              "type": "string"
            },
            "URLFilteringProfile": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "required": [
    "RuleStackName",
    "RuleStackEntry"
  ]
}
