{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MsspResponse",
  "description": "MsspResponse schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-mssp-api-mssp-response-schema.json",
  "type": "object",
  "properties": {
    "msspId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "integer",
      "format": "int64"
    },
    "customerSupportId": {
      "type": "string"
    },
    "contactInfo": {
      "required": [
        "email",
        "firstName",
        "lastName"
      ],
      "type": "object",
      "properties": {
        "firstName": {
          "maxLength": 63,
          "minLength": 1,
          "type": "string"
        },
        "lastName": {
          "maxLength": 63,
          "minLength": 1,
          "type": "string"
        },
        "email": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        }
      }
    }
  }
}
