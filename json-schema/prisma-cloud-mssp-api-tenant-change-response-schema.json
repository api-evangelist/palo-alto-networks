{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TenantChangeResponse",
  "description": "TenantChangeResponse schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-cloud-mssp-api-tenant-change-response-schema.json",
  "type": "object",
  "properties": {
    "tenantChangeId": {
      "type": "string",
      "format": "uuid"
    },
    "externalTenantId": {
      "type": "string"
    },
    "tenantPrismaId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "IN_PROGRESS",
        "SUCCESS",
        "FAILURE"
      ]
    },
    "updatedAt": {
      "type": "integer",
      "format": "int64"
    }
  }
}
