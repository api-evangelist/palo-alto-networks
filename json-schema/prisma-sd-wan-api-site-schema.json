{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Site",
  "description": "Site schema from Palo Alto Networks Prisma SD-WAN API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/prisma-sd-wan-api-site-schema.json",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the site.",
      "readOnly": true
    },
    "name": {
      "type": "string",
      "description": "Name of the SD-WAN site."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the site."
    },
    "admin_state": {
      "type": "string",
      "enum": [
        "active",
        "disabled"
      ],
      "default": "active",
      "description": "Administrative state of the site."
    },
    "element_cluster_role": {
      "type": "string",
      "enum": [
        "SPOKE",
        "HUB",
        "NONE"
      ],
      "default": "SPOKE",
      "description": "Role of the site in the SD-WAN topology."
    },
    "address": {
      "type": "object",
      "description": "Physical address of the site.",
      "properties": {
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "post_code": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    },
    "location": {
      "type": "object",
      "description": "Geographic coordinates of the site.",
      "properties": {
        "latitude": {
          "type": "number",
          "format": "double"
        },
        "longitude": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for organizing and filtering sites."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "readOnly": true
    }
  },
  "required": [
    "name"
  ]
}
