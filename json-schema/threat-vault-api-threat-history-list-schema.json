{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ThreatHistoryList",
  "description": "ThreatHistoryList schema from Palo Alto Networks Threat Vault API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/threat-vault-api-threat-history-list-schema.json",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "A historical record of a signature version.",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string",
            "description": "Content version number for this history entry."
          },
          "release_time": {
            "type": "string",
            "format": "date-time"
          },
          "action": {
            "type": "string",
            "enum": [
              "added",
              "modified",
              "deprecated"
            ]
          }
        }
      }
    },
    "total": {
      "type": "integer"
    },
    "offset": {
      "type": "integer"
    },
    "limit": {
      "type": "integer"
    }
  }
}
