{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommitStatus",
  "description": "Status of a commit job.",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/pan-os-rest-api-commit-status-schema.json",
  "type": "object",
  "properties": {
    "@status": {
      "type": "string"
    },
    "@code": {
      "type": "string"
    },
    "result": {
      "type": "object",
      "properties": {
        "job": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "type": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "ACT",
                "PEND",
                "FIN",
                "WARN"
              ]
            },
            "result": {
              "type": "string",
              "enum": [
                "OK",
                "FAIL",
                "WARN"
              ]
            },
            "progress": {
              "type": "string",
              "description": "Commit progress percentage (0-100)."
            },
            "details": {
              "type": "object",
              "properties": {
                "line": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
