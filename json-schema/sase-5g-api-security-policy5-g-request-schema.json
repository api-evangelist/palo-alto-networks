{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityPolicy5GRequest",
  "description": "SecurityPolicy5GRequest schema from Palo Alto Networks SASE 5G Managed Services API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-schema/sase-5g-api-security-policy5-g-request-schema.json",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for the security policy."
    },
    "description": {
      "type": "string",
      "description": "Optional description."
    },
    "threat_prevention": {
      "type": "boolean",
      "default": true
    },
    "url_filtering": {
      "type": "boolean",
      "default": false
    },
    "app_identification": {
      "type": "boolean",
      "default": true
    },
    "decryption": {
      "type": "boolean",
      "default": false
    },
    "log_forwarding": {
      "type": "boolean",
      "default": true
    },
    "enabled": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}
