{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-access-browser-api-managed-device-structure.json",
  "name": "ManagedDevice",
  "description": "ManagedDevice schema from Palo Alto Networks Prisma Access Browser Management API",
  "type": "object",
  "properties": {
    "device_id": {
      "type": "string",
      "description": "Unique identifier of the managed device."
    },
    "hostname": {
      "type": "string",
      "description": "Device hostname."
    },
    "platform": {
      "type": "string",
      "description": "Operating system platform.",
      "enum": [
        "windows",
        "macos",
        "linux",
        "chromeos"
      ]
    },
    "browser_version": {
      "type": "string",
      "description": "Installed Prisma Access Browser version."
    },
    "compliance_status": {
      "type": "string",
      "description": "Device compliance status.",
      "enum": [
        "compliant",
        "non_compliant",
        "unknown"
      ]
    },
    "user_id": {
      "type": "string",
      "description": "ID of the last user who logged in on this device."
    },
    "last_seen_at": {
      "type": "datetime",
      "description": "Timestamp of the device's last check-in."
    }
  }
}
