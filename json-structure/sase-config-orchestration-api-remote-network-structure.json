{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/sase-config-orchestration-api-remote-network-structure.json",
  "name": "RemoteNetwork",
  "description": "RemoteNetwork schema from Palo Alto Networks SASE Configuration Orchestration API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier of the remote network."
    },
    "name": {
      "type": "string",
      "description": "Display name of the remote network."
    },
    "description": {
      "type": "string",
      "description": "Description of the remote network's location or purpose."
    },
    "location": {
      "type": "string",
      "description": "Prisma Access gateway location for this tunnel."
    },
    "subnets": {
      "type": "array",
      "description": "Network subnets at the remote site (CIDR notation).",
      "items": {
        "type": "string"
      }
    },
    "ike_gateway": {
      "type": "object",
      "properties": {
        "peer_ip": {
          "type": "string",
          "description": "Public IP address of the remote peer gateway."
        },
        "peer_id": {
          "type": "string",
          "description": "IKE peer identity."
        },
        "local_ip": {
          "type": "string",
          "description": "Prisma Access local IKE gateway IP address."
        },
        "ike_version": {
          "type": "string",
          "description": "IKE protocol version.",
          "enum": [
            "IKEv1",
            "IKEv2"
          ]
        },
        "authentication_type": {
          "type": "string",
          "description": "IKE authentication method.",
          "enum": [
            "pre-shared-key",
            "certificate"
          ]
        }
      }
    },
    "ipsec_tunnel": {
      "type": "object",
      "properties": {
        "local_address": {
          "type": "string",
          "description": "Local tunnel IP address assigned by Prisma Access."
        },
        "remote_address": {
          "type": "string",
          "description": "Remote tunnel IP address."
        },
        "tunnel_interface": {
          "type": "string",
          "description": "Tunnel interface name."
        }
      }
    },
    "tunnel_status": {
      "type": "string",
      "description": "Current IPsec tunnel connection status.",
      "enum": [
        "connected",
        "disconnected",
        "pending",
        "error"
      ]
    },
    "bandwidth_mbps": {
      "type": "int32",
      "description": "Allocated bandwidth in Mbps for this remote network."
    },
    "created_at": {
      "type": "datetime"
    },
    "updated_at": {
      "type": "datetime"
    }
  }
}
