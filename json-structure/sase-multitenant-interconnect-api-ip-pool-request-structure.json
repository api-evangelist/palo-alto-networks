{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/sase-multitenant-interconnect-api-ip-pool-request-structure.json",
  "name": "IPPoolRequest",
  "description": "IPPoolRequest schema from SP Interconnect Manage APIs",
  "type": "object",
  "properties": {
    "ipBlocks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "edgeLocation": {
            "type": "string"
          },
          "cidr": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "PRIMARY",
              "SECONDARY"
            ]
          }
        },
        "required": [
          "cidr"
        ]
      }
    },
    "ipProvider": {
      "type": "string",
      "enum": [
        "SP",
        "PANW"
      ]
    }
  },
  "required": [
    "ipProvider"
  ]
}
