{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-mssp-api-tenant-group-policy-group-mapping-structure.json",
  "name": "TenantGroupPolicyGroupMapping",
  "description": "Tenant group to Policy groups mappings.",
  "type": "object",
  "properties": {
    "tenantGroupId": {
      "type": "uuid",
      "description": "Tenant group to which the policy groups are mapped."
    },
    "policyGroupIds": {
      "type": "array",
      "description": "Policy groups to be mapped.",
      "items": {
        "type": "uuid",
        "description": "Policy groups to be mapped."
      }
    }
  },
  "required": [
    "policyGroupIds",
    "tenantGroupId"
  ]
}
