{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/saas-security-api-asset-structure.json",
  "name": "Asset",
  "description": "Asset schema from Palo Alto Networks SaaS Security API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique asset identifier."
    },
    "name": {
      "type": "string",
      "description": "Asset name or filename."
    },
    "type": {
      "type": "string",
      "description": "Asset type.",
      "enum": [
        "file",
        "folder",
        "email",
        "calendar_event",
        "contact"
      ]
    },
    "app_id": {
      "type": "string",
      "description": "ID of the SaaS application containing the asset."
    },
    "app_name": {
      "type": "string",
      "description": "Name of the SaaS application."
    },
    "owner": {
      "type": "string",
      "description": "User ID of the asset owner."
    },
    "exposure": {
      "type": "string",
      "description": "Current exposure level of the asset.",
      "enum": [
        "private",
        "internal",
        "external",
        "public"
      ]
    },
    "size_bytes": {
      "type": "int32",
      "description": "Asset size in bytes."
    },
    "dlp_violations": {
      "type": "array",
      "description": "DLP policy violation names triggered for this asset.",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "datetime"
    },
    "updated_at": {
      "type": "datetime"
    },
    "last_scanned_at": {
      "type": "datetime"
    }
  }
}
