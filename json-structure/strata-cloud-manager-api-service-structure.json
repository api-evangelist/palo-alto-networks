{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/strata-cloud-manager-api-service-structure.json",
  "name": "Service",
  "description": "A service object defining a protocol and port combination for use in security policy rules.",
  "type": "object",
  "properties": {
    "id": {
      "type": "uuid"
    },
    "name": {
      "type": "string"
    },
    "folder": {
      "type": "string"
    },
    "protocol": {
      "type": "object",
      "properties": {
        "tcp": {
          "type": "object",
          "properties": {
            "port": {
              "type": "string",
              "description": "TCP destination port or range (e.g., 80, 8080-8090)."
            },
            "source_port": {
              "type": "string"
            }
          }
        },
        "udp": {
          "type": "object",
          "properties": {
            "port": {
              "type": "string",
              "description": "UDP destination port or range (e.g., 53)."
            },
            "source_port": {
              "type": "string"
            }
          }
        }
      }
    },
    "description": {
      "type": "string"
    },
    "tag": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
