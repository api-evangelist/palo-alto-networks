  "name": "RuleStackSummary",
  "description": "RuleStackSummary schema from Palo Alto Networks Cloud NGFW for AWS REST API",
  "type": "object",
  "properties": {
    "RuleStackName": {
      "type": "string"
    },
    "Scope": {
      "type": "string",
      "enum": [
        "Local",
        "Global"
      ]
    },
    "Status": {
      "type": "string",
      "enum": [
