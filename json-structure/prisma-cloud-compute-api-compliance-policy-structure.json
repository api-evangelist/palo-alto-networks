{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-compute-api-compliance-policy-structure.json",
  "name": "CompliancePolicy",
  "description": "CompliancePolicy schema from Palo Alto Networks Prisma Cloud Compute API",
  "type": "object",
  "properties": {
    "rules": {
      "type": "array",
      "description": "Ordered list of compliance policy rules.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "collections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "effect": {
            "type": "string",
            "enum": [
              "ignore",
              "alert",
              "block"
            ]
          },
          "condition": {
            "type": "object",
            "properties": {
              "checks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "int32",
                      "description": "Compliance check ID."
                    },
                    "block": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
