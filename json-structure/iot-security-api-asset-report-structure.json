{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/iot-security-api-asset-report-structure.json",
  "name": "AssetReport",
  "description": "AssetReport schema from Palo Alto Networks IoT Security API",
  "type": "object",
  "properties": {
    "total_devices": {
      "type": "int32",
      "description": "Total number of discovered devices."
    },
    "monitored_devices": {
      "type": "int32",
      "description": "Number of actively monitored devices."
    },
    "by_category": {
      "type": "object",
      "description": "Device count breakdown by category.",
      "additionalProperties": {
        "type": "int32"
      }
    },
    "by_risk_level": {
      "type": "object",
      "description": "Device count breakdown by risk level.",
      "properties": {
        "critical": {
          "type": "int32"
        },
        "high": {
          "type": "int32"
        },
        "medium": {
          "type": "int32"
        },
        "low": {
          "type": "int32"
        }
      }
    },
    "by_site": {
      "type": "array",
      "description": "Device count breakdown by network site.",
      "items": {
        "type": "object",
        "properties": {
          "site": {
            "type": "string"
          },
          "device_count": {
            "type": "int32"
          }
        }
      }
    },
    "top_profiles": {
      "type": "array",
      "description": "Most common device profiles.",
      "items": {
        "type": "object",
        "properties": {
          "profile": {
            "type": "string"
          },
          "device_count": {
            "type": "int32"
          }
        }
      }
    },
    "report_time": {
      "type": "datetime",
      "description": "Timestamp when the report was generated."
    }
  }
}
