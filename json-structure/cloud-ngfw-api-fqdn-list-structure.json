{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/cloud-ngfw-api-fqdn-list-structure.json",
  "name": "FqdnList",
  "description": "An FQDN list containing domain name entries for use in security rule destination criteria.",
  "type": "object",
  "properties": {
    "FqdnListName": {
      "type": "string"
    },
    "FqdnListEntry": {
      "type": "object",
      "properties": {
        "Description": {
          "type": "string"
        },
        "FqdnList": {
          "type": "array",
          "description": "Fully qualified domain names (e.g., example.com, *.example.com).",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "UpdateToken": {
      "type": "string"
    }
  }
}
