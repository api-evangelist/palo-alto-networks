{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/strata-cloud-manager-api-service-list-structure.json",
  "name": "ServiceList",
  "description": "ServiceList schema from Palo Alto Networks Strata Cloud Manager API",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "A service object defining a protocol and port combination for use in security policy rules.",
        "properties": {
          "id": {
            "type": "uuid"
          },
          "name": {
            "type": "string"
          },
          "folder": {
            "type": "string"
          },
          "protocol": {
            "type": "object",
            "properties": {
              "tcp": {
                "type": "object",
                "properties": {
                  "port": {
                    "type": "string",
                    "description": "TCP destination port or range (e.g., 80, 8080-8090)."
                  },
                  "source_port": {
                    "type": "string"
                  }
                }
              },
              "udp": {
                "type": "object",
                "properties": {
                  "port": {
                    "type": "string",
                    "description": "UDP destination port or range (e.g., 53)."
                  },
                  "source_port": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "description": {
            "type": "string"
          },
          "tag": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "offset": {
      "type": "int32"
    },
    "total": {
      "type": "int32"
    },
    "limit": {
      "type": "int32"
    }
  }
}
