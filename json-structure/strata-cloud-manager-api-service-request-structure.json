{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/strata-cloud-manager-api-service-request-structure.json",
  "name": "ServiceRequest",
  "description": "ServiceRequest schema from Palo Alto Networks Strata Cloud Manager API",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "protocol": {
      "type": "object",
      "properties": {
        "tcp": {
          "type": "object",
          "properties": {
            "port": {
              "type": "string"
            },
            "source_port": {
              "type": "string"
            }
          }
        },
        "udp": {
          "type": "object",
          "properties": {
            "port": {
              "type": "string"
            },
            "source_port": {
              "type": "string"
            }
          }
        }
      }
    },
    "description": {
      "type": "string"
    },
    "tag": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "name",
    "protocol"
  ]
}
