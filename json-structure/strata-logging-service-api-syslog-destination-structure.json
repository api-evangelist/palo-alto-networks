{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/strata-logging-service-api-syslog-destination-structure.json",
  "name": "SyslogDestination",
  "description": "SyslogDestination schema from Palo Alto Networks Strata Logging Service API",
  "type": "object",
  "properties": {
    "destination_id": {
      "type": "string",
      "description": "Unique identifier of the syslog destination."
    },
    "name": {
      "type": "string",
      "description": "Display name of the destination."
    },
    "server": {
      "type": "string",
      "description": "Syslog server hostname or IP address."
    },
    "port": {
      "type": "int32",
      "description": "Syslog server port."
    },
    "protocol": {
      "type": "string",
      "description": "Transport protocol for syslog delivery.",
      "enum": [
        "UDP",
        "TCP",
        "SSL"
      ]
    },
    "format": {
      "type": "string",
      "description": "Syslog message format.",
      "enum": [
        "IETF",
        "BSD",
        "CSV"
      ]
    },
    "facility": {
      "type": "string",
      "description": "Syslog facility value."
    },
    "enabled": {
      "type": "boolean"
    },
    "created_at": {
      "type": "datetime"
    }
  }
}
