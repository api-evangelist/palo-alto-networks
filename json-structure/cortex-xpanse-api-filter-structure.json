{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/cortex-xpanse-api-filter-structure.json",
  "name": "Filter",
  "description": "A filter criterion for querying Xpanse resources.",
  "type": "object",
  "properties": {
    "field": {
      "type": "string",
      "description": "Field name to filter on."
    },
    "operator": {
      "type": "string",
      "enum": [
        "in",
        "contains",
        "gte",
        "lte",
        "eq",
        "neq"
      ]
    },
    "value": {
      "description": "Filter value (string, integer, or array for \"in\" operator).",
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "int32"
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "int32"
              }
            ]
          }
        }
      ]
    }
  },
  "required": [
    "field",
    "operator",
    "value"
  ]
}
