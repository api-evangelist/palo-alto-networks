{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-access-browser-api-browser-deployment-request-structure.json",
  "name": "BrowserDeploymentRequest",
  "description": "BrowserDeploymentRequest schema from Palo Alto Networks Prisma Access Browser Management API",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for the deployment."
    },
    "description": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "description": "Target operating system platform.",
      "enum": [
        "windows",
        "macos",
        "linux",
        "chromeos"
      ]
    },
    "policy_id": {
      "type": "string",
      "description": "Default browser policy ID for this deployment."
    },
    "update_channel": {
      "type": "string",
      "enum": [
        "stable",
        "beta"
      ],
      "default": "stable"
    }
  },
  "required": [
    "name",
    "platform"
  ]
}
