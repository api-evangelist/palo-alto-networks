{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/sase-multitenant-interconnect-api-settings-entry-structure.json",
  "name": "SettingsEntry",
  "description": "SettingsEntry schema from SP Interconnect Manage APIs",
  "type": "object",
  "properties": {
    "egressType": {
      "type": "string",
      "pattern": "SP|PA"
    },
    "cidr": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^((25[0-5]|2[0-4][0-9]|[0-1]?[0-9]{1,2})(\\.(25[0-5]|2[0-4][0-9]|[0-1]?[0-9]{1,2})){3})\\/(3[0-2]|[1-2][0-9]|[0-9])$"
      }
    }
  },
  "required": [
    "egressType"
  ]
}
