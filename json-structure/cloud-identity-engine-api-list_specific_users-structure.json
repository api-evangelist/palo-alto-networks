{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/cloud-identity-engine-api-list_specific_users-structure.json",
  "name": "list_specific_users",
  "description": "Retrieve specific users matching a name-based filter in a domain. Supports filtering of users based on specific attributes and values (similar to the WHERE clause in SQL).",
  "type": "object",
  "properties": {
    "name": {
      "type": "object",
      "description": "Attribute-based filter.",
      "properties": {
        "attrName": {
          "type": "string",
          "description": "Attribute name",
          "enum": [
            "User Principal Name",
            "Common-Name",
            "Name",
            "Distinguished Name",
            "SAM Account Name",
            "Unique Identifier"
          ]
        },
        "attrValue": {
          "type": "string",
          "description": "Attribute value"
        },
        "match": {
          "type": "string",
          "description": "Value you want to match.",
          "enum": [
            "equal",
            "textSearch"
          ]
        }
      },
      "required": [
        "attrName",
        "attrValue",
        "match"
      ]
    }
  },
  "required": [
    "name"
  ]
}
