{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/sase-notifications-service-info-structure.json",
  "name": "ServiceInfo",
  "description": "Information about a SASE service affected by a notification.",
  "type": "object",
  "properties": {
    "serviceName": {
      "type": "string",
      "description": "Name of the SASE service."
    },
    "serviceStatus": {
      "type": "string",
      "description": "Current operational status of the service.",
      "enum": [
        "operational",
        "degraded",
        "maintenance",
        "outage"
      ]
    },
    "region": {
      "type": "string",
      "description": "Region where the service is deployed."
    }
  }
}
