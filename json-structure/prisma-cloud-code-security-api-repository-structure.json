{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-code-security-api-repository-structure.json",
  "name": "Repository",
  "description": "Repository schema from Palo Alto Networks Prisma Cloud Code Security API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique repository identifier in Prisma Cloud."
    },
    "name": {
      "type": "string",
      "description": "Repository name."
    },
    "owner": {
      "type": "string",
      "description": "Repository owner or organization name."
    },
    "fullName": {
      "type": "string",
      "description": "Full repository name in owner/repo format."
    },
    "sourceType": {
      "type": "string",
      "description": "VCS provider type.",
      "enum": [
        "Github",
        "Gitlab",
        "Bitbucket",
        "AzureRepos",
        "githubEnterprise",
        "gitlabEnterprise",
        "bitbucketEnterprise"
      ]
    },
    "defaultBranch": {
      "type": "string",
      "description": "Default branch of the repository."
    },
    "url": {
      "type": "string",
      "description": "URL to the repository in the VCS provider."
    },
    "isPublic": {
      "type": "boolean",
      "description": "Whether the repository is publicly accessible."
    },
    "lastScanDate": {
      "type": "datetime",
      "description": "Timestamp of the most recent scan."
    },
    "lastScanStatus": {
      "type": "string",
      "description": "Status of the most recent scan.",
      "enum": [
        "completed",
        "running",
        "failed",
        "pending"
      ]
    },
    "errorCounts": {
      "type": "object",
      "description": "Count of open errors by severity.",
      "properties": {
        "critical": {
          "type": "int32"
        },
        "high": {
          "type": "int32"
        },
        "medium": {
          "type": "int32"
        },
        "low": {
          "type": "int32"
        },
        "info": {
          "type": "int32"
        }
      }
    },
    "createdAt": {
      "type": "datetime",
      "description": "Timestamp when the repository was connected."
    }
  }
}
