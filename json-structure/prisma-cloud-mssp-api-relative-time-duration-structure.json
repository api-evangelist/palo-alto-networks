{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-mssp-api-relative-time-duration-structure.json",
  "name": "RelativeTimeDuration",
  "description": "RelativeTimeDuration schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "type": "object",
  "properties": {
    "unit": {
      "type": "string",
      "enum": [
        "week",
        "month",
        "year"
      ]
    },
    "amount": {
      "type": "int32",
      "description": "Number of time units"
    }
  }
}
