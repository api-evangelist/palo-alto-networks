{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/sase-config-orchestration-api-ike-gateway-structure.json",
  "name": "IKEGateway",
  "description": "IKEGateway schema from Palo Alto Networks SASE Configuration Orchestration API",
  "type": "object",
  "properties": {
    "peer_ip": {
      "type": "string",
      "description": "Public IP address of the remote peer gateway."
    },
    "peer_id": {
      "type": "string",
      "description": "IKE peer identity."
    },
    "local_ip": {
      "type": "string",
      "description": "Prisma Access local IKE gateway IP address."
    },
    "ike_version": {
      "type": "string",
      "description": "IKE protocol version.",
      "enum": [
        "IKEv1",
        "IKEv2"
      ]
    },
    "authentication_type": {
      "type": "string",
      "description": "IKE authentication method.",
      "enum": [
        "pre-shared-key",
        "certificate"
      ]
    }
  }
}
