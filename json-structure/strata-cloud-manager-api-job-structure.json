{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/strata-cloud-manager-api-job-structure.json",
  "name": "Job",
  "description": "An asynchronous job tracking configuration push or commit operations.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique job identifier."
    },
    "type": {
      "type": "string",
      "description": "Job type (e.g., push, commit)."
    },
    "status": {
      "type": "string",
      "description": "Current job status.",
      "enum": [
        "PEND",
        "ACT",
        "FIN",
        "FAIL"
      ]
    },
    "result": {
      "type": "string",
      "enum": [
        "OK",
        "FAIL",
        "WARN"
      ]
    },
    "start_ts": {
      "type": "datetime",
      "description": "Job start timestamp."
    },
    "end_ts": {
      "type": "datetime",
      "description": "Job completion timestamp."
    },
    "percent": {
      "type": "int32",
      "description": "Job completion percentage (0-100)."
    },
    "details": {
      "type": "object",
      "description": "Additional job details and error messages."
    }
  }
}
