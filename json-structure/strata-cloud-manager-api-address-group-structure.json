{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/strata-cloud-manager-api-address-group-structure.json",
  "name": "AddressGroup",
  "description": "A group of address objects. Can be static with an explicit member list or dynamic with a tag-based filter expression.",
  "type": "object",
  "properties": {
    "id": {
      "type": "uuid"
    },
    "name": {
      "type": "string"
    },
    "folder": {
      "type": "string"
    },
    "static": {
      "type": "array",
      "description": "List of address object names for static groups.",
      "items": {
        "type": "string"
      }
    },
    "dynamic": {
      "type": "object",
      "properties": {
        "filter": {
          "type": "string",
          "description": "Tag-based filter expression (e.g., \"'web-servers' and 'production'\")."
        }
      }
    },
    "description": {
      "type": "string"
    },
    "tag": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
