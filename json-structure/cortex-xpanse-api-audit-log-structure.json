{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/cortex-xpanse-api-audit-log-structure.json",
  "name": "AuditLog",
  "description": "An audit management log entry recording an administrative action.",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "int32",
      "description": "Action timestamp as Unix epoch milliseconds."
    },
    "actor_primary_username": {
      "type": "string"
    },
    "actor_email": {
      "type": "string"
    },
    "actor_type": {
      "type": "string",
      "enum": [
        "User",
        "API"
      ]
    },
    "sub_type": {
      "type": "string",
      "description": "Action subtype (e.g., Login, IpRangeModified, RuleUpdated)."
    },
    "result": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "FAIL"
      ]
    },
    "reason": {
      "type": "string"
    },
    "ip": {
      "type": "string",
      "description": "Source IP address of the action."
    },
    "description": {
      "type": "string"
    }
  }
}
