{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-cspm-api-cloud-account-structure.json",
  "name": "CloudAccount",
  "description": "CloudAccount schema from Palo Alto Networks Prisma Cloud CSPM API",
  "type": "object",
  "properties": {
    "accountId": {
      "type": "string",
      "description": "Cloud provider account identifier."
    },
    "name": {
      "type": "string",
      "description": "Display name of the account."
    },
    "cloudType": {
      "type": "string",
      "description": "Cloud provider type.",
      "enum": [
        "aws",
        "azure",
        "gcp",
        "oci"
      ]
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether monitoring is enabled."
    },
    "numberOfPolicies": {
      "type": "int32",
      "description": "Number of policies applied to this account."
    },
    "lastModifiedTs": {
      "type": "int32",
      "description": "Epoch timestamp of last modification."
    }
  }
}
