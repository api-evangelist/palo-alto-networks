{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/sase-5g-api-network-slice-request-structure.json",
  "name": "NetworkSliceRequest",
  "description": "NetworkSliceRequest schema from Palo Alto Networks SASE 5G Managed Services API",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name for the network slice."
    },
    "description": {
      "type": "string",
      "description": "Optional description."
    },
    "slice_type": {
      "type": "string",
      "description": "5G slice type.",
      "enum": [
        "eMBB",
        "URLLC",
        "mMTC"
      ]
    },
    "sd": {
      "type": "string",
      "description": "Slice Differentiator hex string."
    },
    "security_policy_id": {
      "type": "string",
      "description": "Security policy ID to apply to this slice."
    }
  },
  "required": [
    "name",
    "slice_type"
  ]
}
