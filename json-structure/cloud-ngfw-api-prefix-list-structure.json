{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/cloud-ngfw-api-prefix-list-structure.json",
  "name": "PrefixList",
  "description": "An IP prefix list containing CIDR entries for use in security rule source and destination criteria.",
  "type": "object",
  "properties": {
    "PrefixListName": {
      "type": "string"
    },
    "PrefixListEntry": {
      "type": "object",
      "properties": {
        "Description": {
          "type": "string"
        },
        "PrefixList": {
          "type": "array",
          "description": "CIDR block entries (e.g., 10.0.0.0/8, 192.168.0.0/16).",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "UpdateToken": {
      "type": "string"
    }
  }
}
