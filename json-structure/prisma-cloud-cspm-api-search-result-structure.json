{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-cspm-api-search-result-structure.json",
  "name": "SearchResult",
  "description": "SearchResult schema from Palo Alto Networks Prisma Cloud CSPM API",
  "type": "object",
  "properties": {
    "cloudType": {
      "type": "string",
      "description": "Cloud provider type for the search results."
    },
    "query": {
      "type": "string",
      "description": "RQL query that was executed."
    },
    "data": {
      "type": "object",
      "properties": {
        "totalRows": {
          "type": "int32",
          "description": "Total number of matching resources."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "cloudType": {
                "type": "string"
              },
              "accountId": {
                "type": "string"
              },
              "accountName": {
                "type": "string"
              },
              "regionId": {
                "type": "string"
              },
              "resourceType": {
                "type": "string"
              },
              "overallPassed": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}
