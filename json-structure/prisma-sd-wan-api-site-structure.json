{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-sd-wan-api-site-structure.json",
  "name": "Site",
  "description": "Site schema from Palo Alto Networks Prisma SD-WAN API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the site."
    },
    "name": {
      "type": "string",
      "description": "Name of the SD-WAN site."
    },
    "description": {
      "type": "string",
      "description": "Optional description of the site."
    },
    "admin_state": {
      "type": "string",
      "description": "Administrative state of the site.",
      "enum": [
        "active",
        "disabled"
      ],
      "default": "active"
    },
    "element_cluster_role": {
      "type": "string",
      "description": "Role of the site in the SD-WAN topology.",
      "enum": [
        "SPOKE",
        "HUB",
        "NONE"
      ],
      "default": "SPOKE"
    },
    "address": {
      "type": "object",
      "description": "Physical address of the site.",
      "properties": {
        "street": {
          "type": "string"
        },
        "city": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "post_code": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      }
    },
    "location": {
      "type": "object",
      "description": "Geographic coordinates of the site.",
      "properties": {
        "latitude": {
          "type": "double"
        },
        "longitude": {
          "type": "double"
        }
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for organizing and filtering sites.",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "datetime"
    },
    "updated_at": {
      "type": "datetime"
    }
  },
  "required": [
    "name"
  ]
}
