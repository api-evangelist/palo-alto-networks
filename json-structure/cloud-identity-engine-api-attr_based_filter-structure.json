{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/cloud-identity-engine-api-attr_based_filter-structure.json",
  "name": "attr_based_filter",
  "description": "Attribute-based filter.",
  "type": "object",
  "properties": {
    "attrName": {
      "type": "string",
      "description": "Attribute name",
      "enum": [
        "User Principal Name",
        "Common-Name",
        "Name",
        "Distinguished Name",
        "SAM Account Name",
        "Unique Identifier"
      ]
    },
    "attrValue": {
      "type": "string",
      "description": "Attribute value"
    },
    "match": {
      "type": "string",
      "description": "Value you want to match.",
      "enum": [
        "equal",
        "textSearch"
      ]
    }
  },
  "required": [
    "attrName",
    "attrValue",
    "match"
  ]
}
