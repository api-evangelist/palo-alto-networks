{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-sd-wan-api-wan-interface-structure.json",
  "name": "WANInterface",
  "description": "WANInterface schema from Palo Alto Networks Prisma SD-WAN API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the WAN interface."
    },
    "name": {
      "type": "string",
      "description": "Name of the WAN interface."
    },
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "description": "Type of WAN connection.",
      "enum": [
        "publicwan",
        "privatewan"
      ]
    },
    "link_bw_down": {
      "type": "double",
      "description": "Downstream bandwidth in Mbps."
    },
    "link_bw_up": {
      "type": "double",
      "description": "Upstream bandwidth in Mbps."
    },
    "cost": {
      "type": "int32",
      "description": "Cost metric for path selection. Lower cost is preferred.",
      "minimum": 0,
      "maximum": 255
    },
    "lqm_enabled": {
      "type": "boolean",
      "description": "Whether Link Quality Monitoring is enabled.",
      "default": true
    },
    "label_id": {
      "type": "string",
      "description": "WAN interface label for policy-based routing."
    },
    "site_id": {
      "type": "string"
    },
    "created_at": {
      "type": "datetime"
    },
    "updated_at": {
      "type": "datetime"
    }
  },
  "required": [
    "name",
    "type"
  ]
}
