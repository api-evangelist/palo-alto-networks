{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-mssp-api-create-managed-tenant-request-structure.json",
  "name": "CreateManagedTenantRequest",
  "description": "CreateManagedTenantRequest schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63
    },
    "companyName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63
    },
    "region": {
      "type": "string"
    },
    "tenantGroupId": {
      "type": "uuid"
    },
    "planType": {
      "type": "string",
      "enum": [
        "RS_STANDARD",
        "RS_FOUNDATION",
        "RS_ADVANCED"
      ]
    },
    "contactInfo": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63
        },
        "email": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "email",
        "firstName",
        "lastName"
      ]
    },
    "licenseInfo": {
      "type": "object",
      "properties": {
        "licensePoolId": {
          "type": "string"
        },
        "allocatedCredits": {
          "type": "int32",
          "minimum": 1
        }
      },
      "required": [
        "allocatedCredits",
        "licensePoolId"
      ]
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "featureName": {
            "type": "string",
            "pattern": "iam-security"
          },
          "enabled": {
            "type": "boolean"
          },
          "additionalData": {
            "type": "object",
            "additionalProperties": {
              "type": "object"
            }
          }
        },
        "required": [
          "enabled",
          "featureName"
        ]
      }
    }
  },
  "required": [
    "companyName",
    "contactInfo",
    "licenseInfo",
    "name",
    "planType",
    "region"
  ]
}
