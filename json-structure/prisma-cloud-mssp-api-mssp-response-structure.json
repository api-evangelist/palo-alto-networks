{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-mssp-api-mssp-response-structure.json",
  "name": "MsspResponse",
  "description": "MsspResponse schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "type": "object",
  "properties": {
    "msspId": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "createdBy": {
      "type": "string"
    },
    "createdAt": {
      "type": "int64"
    },
    "customerSupportId": {
      "type": "string"
    },
    "contactInfo": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63
        },
        "lastName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63
        },
        "email": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "required": [
        "email",
        "firstName",
        "lastName"
      ]
    }
  }
}
