{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-airs-api-ai-profile-structure.json",
  "name": "AIProfile",
  "description": "AIProfile schema from Palo Alto Networks Prisma AIRS API",
  "type": "object",
  "properties": {
    "profile_id": {
      "type": "string",
      "description": "Unique identifier of the profile."
    },
    "profile_name": {
      "type": "string",
      "description": "Profile name used to reference this profile in scan requests."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the profile purpose and use case."
    },
    "detection_categories": {
      "type": "array",
      "description": "Detection categories configured in this profile.",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "prompt_injection",
              "jailbreak",
              "data_leakage",
              "toxic_content",
              "malicious_url",
              "pii_exposure",
              "model_abuse"
            ]
          },
          "enabled": {
            "type": "boolean",
            "description": "Whether this detection category is active."
          },
          "sensitivity": {
            "type": "string",
            "description": "Detection sensitivity threshold.",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "action": {
            "type": "string",
            "description": "Enforcement action when this category triggers.",
            "enum": [
              "alert",
              "block",
              "log"
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "datetime",
      "description": "Timestamp when the profile was created."
    },
    "updated_at": {
      "type": "datetime",
      "description": "Timestamp of the most recent profile modification."
    }
  }
}
