{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-mssp-api-update-managed-tenant-request-structure.json",
  "name": "UpdateManagedTenantRequest",
  "description": "UpdateManagedTenantRequest schema from Prisma Cloud: Managed Security Service Provider (MSSP)",
  "type": "object",
  "properties": {
    "tenantGroupId": {
      "type": "uuid"
    },
    "companyName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 63
    },
    "licenseInfo": {
      "type": "object",
      "properties": {
        "licensePoolId": {
          "type": "string"
        },
        "allocatedCredits": {
          "type": "int32",
          "minimum": 1
        }
      },
      "required": [
        "allocatedCredits",
        "licensePoolId"
      ]
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "featureName": {
            "type": "string",
            "pattern": "iam-security"
          },
          "enabled": {
            "type": "boolean"
          },
          "additionalData": {
            "type": "object",
            "additionalProperties": {
              "type": "object"
            }
          }
        },
        "required": [
          "enabled",
          "featureName"
        ]
      }
    }
  }
}
