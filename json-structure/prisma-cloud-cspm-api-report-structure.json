{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/prisma-cloud-cspm-api-report-structure.json",
  "name": "Report",
  "description": "Report schema from Palo Alto Networks Prisma Cloud CSPM API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique report identifier."
    },
    "name": {
      "type": "string",
      "description": "Report name."
    },
    "type": {
      "type": "string",
      "description": "Report type.",
      "enum": [
        "RIS",
        "COMPLIANCE",
        "ALERT"
      ]
    },
    "status": {
      "type": "string",
      "description": "Current report generation status.",
      "enum": [
        "pending",
        "processing",
        "completed",
        "failed"
      ]
    },
    "createdOn": {
      "type": "int32",
      "description": "Epoch timestamp when the report was created."
    },
    "lastModifiedOn": {
      "type": "int32",
      "description": "Epoch timestamp of last modification."
    },
    "downloadUrl": {
      "type": "string",
      "description": "URL for downloading the completed report."
    }
  }
}
