{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/palo-alto-networks/refs/heads/main/json-structure/saas-security-api-user-structure.json",
  "name": "User",
  "description": "User schema from Palo Alto Networks SaaS Security API",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique user identifier."
    },
    "email": {
      "type": "string",
      "description": "User email address."
    },
    "display_name": {
      "type": "string",
      "description": "User display name."
    },
    "app_id": {
      "type": "string",
      "description": "SaaS application ID the user belongs to."
    },
    "account_type": {
      "type": "string",
      "description": "Type of user account.",
      "enum": [
        "internal",
        "external",
        "service"
      ]
    },
    "last_activity": {
      "type": "datetime",
      "description": "Timestamp of the user's most recent activity."
    }
  }
}
