{
  "@context": {
    "@version": 1.1,
    "pan": "https://pan.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "EventDataPayload": "pan:EventDataPayload",
    "LogDataPayload": "pan:LogDataPayload",
    "XdrDataPayload": "pan:XdrDataPayload",
    "dataset": {
      "@id": "pan:dataset",
      "@type": "xsd:string"
    },
    "eventId": {
      "@id": "pan:event_id",
      "@type": "xsd:string"
    },
    "logType": {
      "@id": "pan:log_type",
      "@type": "xsd:string"
    },
    "product": {
      "@id": "pan:product",
      "@type": "xsd:string"
    },
    "rawLog": {
      "@id": "pan:raw_log",
      "@type": "xsd:string"
    },
    "tenantId": {
      "@id": "pan:tenant_id",
      "@type": "xsd:string"
    },
    "timestamp": {
      "@id": "pan:timestamp",
      "@type": "xsd:dateTime"
    },
    "vendor": {
      "@id": "pan:vendor",
      "@type": "xsd:string"
    }
  }
}
