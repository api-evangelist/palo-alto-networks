{
  "@context": {
    "@version": 1.1,
    "pan": "https://pan.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "attr_based_filter": "pan:attr_based_filter",
    "check_group_membership": "pan:check_group_membership",
    "check_user_in_particular_group": "pan:check_user_in_particular_group",
    "domain_param": "pan:domain_param",
    "fetch_all_users_attrs": "pan:fetch_all_users_attrs",
    "group_filter": "pan:group_filter",
    "list_all_groups_in_domain": "pan:list_all_groups_in_domain",
    "list_all_users_in_domain": "pan:list_all_users_in_domain",
    "list_groups_user_belongs_to": "pan:list_groups_user_belongs_to",
    "list_specific_groups": "pan:list_specific_groups",
    "list_specific_users": "pan:list_specific_users",
    "list_users_in_particular_group": "pan:list_users_in_particular_group",
    "pagination_params": "pan:pagination_params",
    "attrName": {
      "@id": "pan:attrName",
      "@type": "xsd:string"
    },
    "attrValue": {
      "@id": "pan:attrValue",
      "@type": "xsd:string"
    },
    "attrs": {
      "@id": "pan:attrs",
      "@container": "@set",
      "@type": "xsd:string"
    },
    "domain": {
      "@id": "pan:domain",
      "@type": "xsd:string"
    },
    "filter": {
      "@id": "pan:filter",
      "@type": "@id"
    },
    "level": {
      "@id": "pan:level",
      "@type": "xsd:string"
    },
    "match": {
      "@id": "pan:match",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "@id"
    },
    "pageNum": {
      "@id": "pan:pageNum",
      "@type": "xsd:integer"
    },
    "pageSz": {
      "@id": "pan:pageSz",
      "@type": "xsd:integer"
    },
    "type": {
      "@id": "pan:type",
      "@type": "xsd:string"
    },
    "useNormalizedAttrs": {
      "@id": "pan:useNormalizedAttrs",
      "@type": "xsd:string"
    }
  }
}
