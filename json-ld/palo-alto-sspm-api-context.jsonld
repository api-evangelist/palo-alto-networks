    },
    "appType": {
      "@id": "pan:app_type",
      "@type": "xsd:string"
    },
    "category": {
      "@id": "pan:category",
      "@type": "xsd:string"
    },
    "checkCount": {
      "@id": "pan:check_count",
      "@type": "xsd:integer"
    },
    "checkId": {
      "@id": "pan:check_id",
      "@type": "xsd:string"
    },
    "checkName": {
      "@id": "pan:check_name",
      "@type": "xsd:string"
    },
    "checkSummary": {
      "@id": "pan:check_summary",
