    },
    "lastScannedAt": {
      "@id": "pan:last_scanned_at",
      "@type": "xsd:dateTime"
    },
    "logoUrl": {
      "@id": "pan:logo_url",
      "@type": "@id"
    },
    "low": {
      "@id": "pan:low",
      "@type": "xsd:integer"
    },
    "medium": {
      "@id": "pan:medium",
      "@type": "xsd:integer"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "onboardedAt": {
      "@id": "pan:onboarded_at",
      "@type": "xsd:dateTime"
    },
    "pass": {
      "@id": "pan:pass",
