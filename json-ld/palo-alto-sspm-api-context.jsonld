    },
    "credentials": {
      "@id": "pan:credentials",
      "@type": "@id"
    },
    "critical": {
      "@id": "pan:critical",
      "@type": "xsd:integer"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "displayName": {
      "@id": "pan:display_name",
      "@type": "xsd:string"
    },
    "email": {
      "@id": "schema:email",
      "@type": "xsd:string"
    },
    "enabled": {
      "@id": "pan:enabled",
      "@type": "xsd:boolean"
    },
    "high": {
      "@id": "pan:high",
      "@type": "xsd:integer"
    },
    "id": {
      "@id": "pan:id",
      "@type": "xsd:string"
    },
    "issueType": {
      "@id": "pan:issue_type",
      "@type": "xsd:string"
    },
    "jiraUrl": {
      "@id": "pan:jira_url",
      "@type": "@id"
    },
    "lastEvaluatedAt": {
      "@id": "pan:last_evaluated_at",
