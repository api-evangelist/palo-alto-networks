{
  "@context": {
    "@version": 1.1,
    "pan": "https://pan.dev/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "NetworkSlice": "pan:NetworkSlice",
    "NetworkSliceRequest": "pan:NetworkSliceRequest",
    "SecurityMetrics5G": "pan:SecurityMetrics5G",
